{
  "name": "ai-generation-stations",
  "private": true,
  "scripts": {
    "start": "node server/index.js",
    "dev": "node server/index.js",
    "check": "node --check server/index.js",
    "test": "node test-suite.js",
    "test:auth-history": "node test-auth-history.js",
    "test:task-persistence": "node test-task-persistence.js",
    "test:frontend": "node test-frontend-state.js && node test-page-markup.js",
    "test:ui-flow": "node test-ui-flow-smoke.js",
    "test:ui-visual": "node test-ui-visual.js",
    "test:ui-visual:update": "node test-ui-visual.js --update-baseline",
    "test:style-contract": "node test-style-contract.js",
    "test:capacity-baseline": "node test-capacity-baseline.js",
    "test:regression": "node test-regression.js",
    "test:regression-core": "node test-regression.js --skip-live --skip-browser",
    "test:release-browser": "node test-style-contract.js && node test-page-markup.js && node test-frontend-state.js && node test-auth-history.js && node test-ui-flow-smoke.js --port 18797 --launch-server && node test-ui-visual.js --port 18797 --launch-server && node test-failures.js && node test-security-gateway.js && node test-capacity-baseline.js && node test-regression.js --skip-live --port 18797 && node test-regression.js",
    "test:release-core": "node test-regression.js --skip-live --skip-browser && node test-capacity-baseline.js",
    "test:security-boundaries": "node test-api-auth-boundary.js && node test-output-access-boundary.js && node test-http-body-limit.js && node test-error-disclosure.js && node test-config-production-safety.js",
    "test:state-maintenance": "node test-state-maintenance.js",
    "test:failures": "node test-failures.js",
    "test:lyrics": "node test-lyrics.js",
    "test:music": "node test-music.js",
    "test:image": "node test-image.js",
    "test:cover": "node test-cover.js",
    "test:voice-cover": "node test-voice-cover.js"
  },
  "dependencies": {
    "axios": "^1.15.0",
    "dotenv": "^17.2.3",
    "global-agent": "^4.1.3",
    "https-proxy-agent": "^9.0.0",
    "node-fetch": "^2.7.0",
    "proxy-agent": "^8.0.1"
  },
  "devDependencies": {
    "pixelmatch": "^7.1.0",
    "playwright": "^1.59.1",
    "pngjs": "^7.0.0"
  }
}
